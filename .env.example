# Database
DATABASE_URL=postgresql://nemt:nemt_secret@localhost:5432/nemt?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d

# API
API_PORT=3001
# Local:
CORS_ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=http://localhost:3001
# Production (mediride.net — Nginx proxies /api to the API container):
# CORS_ORIGIN=https://mediride.net
# NEXT_PUBLIC_API_URL=https://mediride.net/api
# NEXT_PUBLIC_WS_URL=https://mediride.net

# Mapbox (get free token at https://account.mapbox.com)
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_token_here

# Infisical (optional in local; used in production)
INFISICAL_TOKEN=
INFISICAL_PROJECT_ID=
INFISICAL_ENV=dev

# Twilio SMS (optional — without these, SMS is logged to API console only)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
